generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiMetric {
  id           Int      @id @default(autoincrement())
  apiId        String   
  timestamp    DateTime @default(now())
  responseTime Int
  status       Int
  success      Boolean

  @@index([apiId, timestamp])
}
